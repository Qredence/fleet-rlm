{
  "name": "@qredence/hax-fleet",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "src/main.tsx",
    "src/styles/**/*"
  ],
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "type-check": "tsc -p tsconfig.app.json --noEmit",
    "type-check:relaxed": "tsc -p tsconfig.app.json --noEmit --strict false --noUnusedLocals false --noUnusedParameters false --noUncheckedIndexedAccess false",
    "lint": "vp lint src/",
    "lint:robustness": "pnpm run lint",
    "format": "vp fmt src/",
    "format:check": "vp fmt --check src/",
    "test:e2e": "playwright test",
    "test:unit": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "api:sync-spec": "mkdir -p openapi && OPENAPI_SPEC_PATH=\"${OPENAPI_SPEC_PATH:-../../openapi.yaml}\" && cp \"$OPENAPI_SPEC_PATH\" openapi/fleet-rlm.openapi.yaml",
    "api:types": "openapi-typescript openapi/fleet-rlm.openapi.yaml -o src/lib/rlm-api/generated/openapi.ts",
    "api:sync": "pnpm run api:sync-spec && pnpm run api:types && pnpm exec vp check --fix openapi/fleet-rlm.openapi.yaml src/lib/rlm-api/generated/openapi.ts",
    "api:check": "node scripts/check-api-sync.mjs",
    "check": "pnpm run type-check && pnpm run lint && pnpm run test:unit && pnpm run build && pnpm run test:e2e"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.4.0",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@posthog/react": "1.8.2",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.1.0",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.1",
    "@tanstack/router-plugin": "^1.166.10",
    "@visual-json/react": "^0.4.0",
    "@xyflow/react": "^12.10.1",
    "agentation": "^3.0.2",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "nanoid": "^5.1.6",
    "posthog-js": "1.359.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "4.7.3",
    "shiki": "3.23.0",
    "sonner": "2.0.7",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.2.1",
    "@types/bun": "1.3.10",
    "@types/node": "24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "17.4.0",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^6.7.6",
    "prettier": "^3.8.1",
    "tailwindcss": "4.2.1",
    "typescript": "^5.9.3",
    "shadcn": "^4.1.0",
    "typescript-eslint": "8.56.1",    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.11",
    "vite-plus": "^0.1.17",
    "@tanstack/router-devtools": "^1.166.8",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.11"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.11",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.11"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {

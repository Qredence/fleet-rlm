{
  "name": "@qredence/hax-fleet",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.2.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc -p tsconfig.app.json --noEmit",
    "type-check:relaxed": "tsc -p tsconfig.app.json --noEmit --strict false --noUnusedLocals false --noUnusedParameters false --noUncheckedIndexedAccess false",
    "lint": "eslint src/",
    "lint:robustness": "eslint src/app/components/shared/ToggleSwitch.tsx src/app/lib/api/capabilities.ts src/app/components/hooks/useSkills.ts src/app/components/hooks/useMemory.ts src/app/components/hooks/useTaxonomy.ts src/app/components/hooks/useAnalytics.ts src/app/components/hooks/useFilesystem.ts src/app/pages/SkillLibrary.tsx src/app/pages/MemoryPage.tsx src/app/pages/TaxonomyBrowser.tsx src/app/pages/AnalyticsDashboard.tsx src/app/pages/RouteErrorPage.tsx src/app/routes.ts src/app/lib/perf/lazyWithRetry.ts src/app/lib/perf/routePreload.tsx src/app/layout/TopHeader.tsx src/app/components/ui/mobile-tab-bar.tsx src/app/components/ui/nav-tab.tsx src/main.tsx",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "api:sync-spec": "mkdir -p openapi && : \"${OPENAPI_SPEC_PATH:?Set OPENAPI_SPEC_PATH to location of openapi.yaml}\" && cp \"$OPENAPI_SPEC_PATH\" openapi/fleet-rlm.openapi.yaml",
    "api:types": "openapi-typescript openapi/fleet-rlm.openapi.yaml -o src/app/lib/rlm-api/generated/openapi.ts",
    "api:sync": "bun run api:sync-spec && bun run api:types",
    "check": "bun run type-check && bun run lint:robustness && bun run test:unit && bun run build && bun run test:e2e"
  },

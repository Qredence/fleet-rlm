{
  "name": "@qredence/hax-fleet",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.2.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc -p tsconfig.app.json --noEmit",
    "type-check:relaxed": "tsc -p tsconfig.app.json --noEmit --strict false --noUnusedLocals false --noUnusedParameters false --noUncheckedIndexedAccess false",
    "lint": "eslint src/",
    "lint:robustness": "bun run lint",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "api:sync-spec": "mkdir -p openapi && OPENAPI_SPEC_PATH=\"${OPENAPI_SPEC_PATH:-../../openapi.yaml}\" && cp \"$OPENAPI_SPEC_PATH\" openapi/fleet-rlm.openapi.yaml",
    "api:types": "openapi-typescript openapi/fleet-rlm.openapi.yaml -o src/lib/rlm-api/generated/openapi.ts",
    "api:sync": "bun run api:sync-spec && bun run api:types",
    "api:check": "bun run api:sync && git diff --exit-code -- openapi/fleet-rlm.openapi.yaml src/lib/rlm-api/generated/openapi.ts && git diff --cached --exit-code -- openapi/fleet-rlm.openapi.yaml src/lib/rlm-api/generated/openapi.ts",
    "check": "bun run type-check && bun run lint && bun run test:unit && bun run build && bun run test:e2e"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",

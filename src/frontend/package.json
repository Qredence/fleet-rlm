    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/python": "^1.1.18",
    "@marijn/find-cluster-break": "^1.0.2",
    "@monaco-editor/react": "^4.7.0",
    "@posthog/react": "^1.8.0",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",

# fleet-rlm core backend configuration
VITE_FLEET_API_URL=http://localhost:8000

# Include trace/reasoning stream data from backend
VITE_FLEET_TRACE=true

# Microsoft Entra SPA auth
# Multitenant org-only sign-in defaults to:
#   authority: https://login.microsoftonline.com/organizations
#   redirect path: /login
# Scope format:
#   api://<api-app-client-id>/access_as_user
VITE_ENTRA_CLIENT_ID=
# Optional explicit authority override.
# VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/organizations
VITE_ENTRA_SCOPES=
# VITE_ENTRA_REDIRECT_PATH=/login

# Optional PostHog frontend analytics (canonical key)
# v0.4.8 also supports legacy alias `VITE_PUBLIC_POSTHOG_KEY` temporarily.
# If neither key is set, the app will try a project-owned default (if configured in source).
VITE_PUBLIC_POSTHOG_API_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# fleet-rlm Environment Configuration
#
# Copy this file to .env and fill in your own values.
# The .env file is gitignored for security—never commit secrets!
#
# REQUIRED: LLM Configuration (one of the two API key formats below)
#
# The LLM model to use for the planner (DSPy's reasoning engine)
# Examples:
#   - Google: "google/gemini-3-flash-preview"
#   - OpenAI: "openai/gpt-4-turbo"
#   - Anthropic: "anthropic/claude-3-sonnet"
#   - Use a LiteLLM proxy: "openai/your-proxy-endpoint"
DSPY_LM_MODEL=openai/gpt-4.1-mini

# API key for the LLM provider (if using standard OpenAI-compatible endpoint)
# Or use DSPY_LM_API_KEY below as an alternative
DSPY_LLM_API_KEY=sk-...

# Alternative API key name (some providers use this instead)
# Uncomment and use if DSPY_LLM_API_KEY doesn't work for your provider
# DSPY_LM_API_KEY=sk-...

#
# OPTIONAL: Neon Postgres + Auth (for API server persistence)
#

# Direct Neon PostgreSQL URL (recommended runtime path, non-pooler endpoint)
# Example:
# DATABASE_URL=postgresql://user:password@ep-foo-bar.us-east-2.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL=

# Backend auth mode:
# - dev: local debug headers or local HS256 JWT
# - entra: reserved for future Microsoft Entra OIDC token validation
AUTH_MODE=dev

# Require auth on API/WS routes:
# - false (default in dev): auth is optional; server falls back to anonymous identity
# - true: missing/invalid auth is rejected
# NOTE: entra mode always defaults to required=true.
AUTH_REQUIRED=false

# Secret used for local HS256 development tokens
DEV_JWT_SECRET=change-me

# Future Entra wiring (not active yet)
# ENTRA_JWKS_URL=
# ENTRA_ISSUER=
# ENTRA_AUDIENCE=

#
# OPTIONAL: LLM Endpoint and Parameters
#

# Custom API endpoint (if using LiteLLM proxy or self-hosted model)
# Default: OpenAI-compatible endpoint
# Example: "https://api.together.ai/v1"
# DSPY_LM_API_BASE=https://your-litellm-proxy.com

# Maximum tokens for LLM response
# Default: 8192
# Increase for longer outputs, decrease to save tokens
# DSPY_LM_MAX_TOKENS=65536

#
# OPTIONAL: PostHog LLM Analytics
#

# Enable PostHog analytics callback for DSPy LM calls
# Requires both POSTHOG_ENABLED=true and a valid POSTHOG_API_KEY
POSTHOG_ENABLED=false

# PostHog project API key
# POSTHOG_API_KEY=phc_...

# PostHog host (US cloud default)
POSTHOG_HOST=https://us.i.posthog.com

# Optional explicit distinct id (runtime identity takes precedence when available)
# POSTHOG_DISTINCT_ID=anonymous

# Flush cadence for batched analytics events
POSTHOG_FLUSH_INTERVAL=10.0
POSTHOG_FLUSH_AT=10

# Track optimizer traffic (disabled by default to preserve deterministic training workflows)
POSTHOG_ENABLE_DSPY_OPTIMIZATION=false

# Payload capture controls
POSTHOG_INPUT_TRUNCATION=10000
POSTHOG_OUTPUT_TRUNCATION=5000
POSTHOG_REDACT_SENSITIVE=true

#
# NOTES:
# - Modal credentials are per-user: run `modal setup` to configure
# - Modal secrets (API keys) are configured via: modal secret create LITELLM ...
# - Never commit this file once filled with real secrets
# - For team setups, use Modal's secret management instead of .env
#

# fleet-rlm Environment Configuration
#
# Copy this file to .env and fill in your own values.
# The .env file is gitignored for security—never commit secrets!
#
# REQUIRED: LLM Configuration (one of the two API key formats below)
#
# The LLM model to use for the planner (DSPy's reasoning engine)
# Examples:
#   - Google: "google/gemini-3-flash-preview"
#   - OpenAI: "openai/gpt-5.2
#   - Anthropic: "anthropic/claude-3-sonnet"
#   - Use a LiteLLM proxy: "openai/your-proxy-endpoint"
DSPY_LM_MODEL=openai/gemini/gemini-3.1-pro-preview

# API key for the LLM provider (if using standard OpenAI-compatible endpoint)
# Or use DSPY_LM_API_KEY below as an alternative
DSPY_LLM_API_KEY=sk-...

# Alternative API key name (some providers use this instead)
# Uncomment and use if DSPY_LLM_API_KEY doesn't work for your provider
# DSPY_LM_API_KEY=sk-...

#
# OPTIONAL: Neon Postgres + Auth (for API server persistence)
#

# Direct Neon PostgreSQL URL (recommended runtime path, non-pooler endpoint)
# Example:
# DATABASE_URL=postgresql://user:password@ep-foo-bar.us-east-2.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL=

# Backend auth mode:
# - dev: local debug headers or local HS256 JWT
# - entra: Microsoft Entra OIDC bearer token validation for HTTP and WebSocket
AUTH_MODE=dev

# Runtime environment guardrails:
# - local: developer defaults (debug auth enabled, legacy SQLite routes enabled)
# - staging/production: strict auth + Neon persistence defaults
APP_ENV=local

# Require auth on API/WS routes:
# - false (default in dev): auth is optional; server falls back to anonymous identity
# - true: missing/invalid auth is rejected
# NOTE: entra mode always defaults to required=true.
AUTH_REQUIRED=false

# Secret used for local HS256 development tokens
DEV_JWT_SECRET=change-me

# Entra API validation inputs (required when AUTH_MODE=entra)
# ENTRA_JWKS_URL=
# ENTRA_AUDIENCE=
# Optional override for multitenant issuer validation.
# Defaults to https://login.microsoftonline.com/{tenantid}/v2.0
# ENTRA_ISSUER_TEMPLATE=https://login.microsoftonline.com/{tenantid}/v2.0

# Frontend SPA auth inputs (set in src/frontend/.env.local or exported in shell)
# VITE_ENTRA_CLIENT_ID=
# Defaults to https://login.microsoftonline.com/organizations for multitenant org-only sign-in.
# VITE_ENTRA_AUTHORITY=
# VITE_ENTRA_SCOPES=api://<api-app-id>/access_as_user
# VITE_ENTRA_REDIRECT_PATH=/login

# Require Neon repository at runtime. Defaults true in staging/production.
# DATABASE_REQUIRED=true

# Legacy SQLite routes (/api/v1/tasks, /api/v1/sessions CRUD) gate.
# Defaults true only in local APP_ENV.
# LEGACY_SQLITE_ROUTES_ENABLED=true

# Debug auth controls (dev mode only). Defaults true only in local APP_ENV.
# ALLOW_DEBUG_AUTH=true
# ALLOW_QUERY_AUTH_TOKENS=true

# CORS origin allowlist (comma-separated). Defaults "*" in local APP_ENV.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# WS execution stream backpressure settings.
# WS_EXECUTION_MAX_QUEUE=256
# WS_EXECUTION_DROP_POLICY=drop_oldest

#
# OPTIONAL: LLM Endpoint and Parameters
#

# Custom API endpoint (if using LiteLLM proxy or self-hosted model)
# Default: OpenAI-compatible endpoint
# Example: "https://api.together.ai/v1"
# DSPY_LM_API_BASE=https://your-litellm-proxy.com

# Maximum tokens for LLM response
# Default: 8192
# Increase for longer outputs, decrease to save tokens
# DSPY_LM_MAX_TOKENS=65536

#
# OPTIONAL: Daytona Experimental Pilot
#

# Native Daytona credentials for the experimental `fleet-rlm daytona-smoke`
# and `fleet-rlm daytona-rlm` commands.
# Use DAYTONA_API_URL exactly; DAYTONA_API_BASE_URL is not supported.
# DAYTONA_API_KEY=
# DAYTONA_API_URL=https://app.daytona.io/api
# Optional Daytona target/cluster selector.
# DAYTONA_TARGET=

#
# OPTIONAL: PostHog LLM Analytics
#

# Enable PostHog analytics callback for DSPy LM calls.
# If POSTHOG_ENABLED is unset, runtime defaults to enabled when a project-owned
# default key (or explicit POSTHOG_API_KEY) is available.
POSTHOG_ENABLED=false

# PostHog project API key (explicit override). If omitted, runtime may use a
# project-owned default key when configured in source for web/server telemetry.
# POSTHOG_API_KEY=phc_...

# PostHog host (defaults to project canonical host if unset; explicit override supported)
POSTHOG_HOST=https://eu.i.posthog.com

# Optional explicit distinct id (runtime identity takes precedence when available)
# POSTHOG_DISTINCT_ID=anonymous

# Flush cadence for batched analytics events
POSTHOG_FLUSH_INTERVAL=10.0
POSTHOG_FLUSH_AT=10

# Track optimizer traffic (disabled by default to preserve deterministic training workflows)
POSTHOG_ENABLE_DSPY_OPTIMIZATION=false

# Payload capture controls
POSTHOG_INPUT_TRUNCATION=10000
POSTHOG_OUTPUT_TRUNCATION=5000
POSTHOG_REDACT_SENSITIVE=true

#
# OPTIONAL: MLflow Tracing, Feedback, Evaluation, and Optimization
#

# Enable first-class MLflow tracing for DSPy/module execution.
# Set to false to disable MLflow integration entirely.
MLFLOW_ENABLED=true

# Local OSS default. You can also point this at a remote/self-hosted MLflow server.
MLFLOW_TRACKING_URI=http://127.0.0.1:5001

# Auto-start the local MLflow server during `uv run fleet web` / `serve-api`
# when APP_ENV=local and MLFLOW_TRACKING_URI points at localhost. Leave unset
# to use that local-default behavior, or set this to false to manage MLflow
# manually with `make mlflow-server` instead.
# MLFLOW_AUTO_START=false

# Protected remote MLflow servers can use either a bearer token or basic auth.
# Uncomment the option your tracking server expects.
# MLFLOW_TRACKING_TOKEN=replace-with-token
# MLFLOW_TRACKING_USERNAME=replace-with-username
# MLFLOW_TRACKING_PASSWORD=replace-with-password

# Optional TLS override for development against self-signed certs only.
# MLFLOW_TRACKING_INSECURE_TLS=false

# Experiment used for live traces, feedback, offline evaluation, and optimization runs.
MLFLOW_EXPERIMENT=fleet-rlm

# Optional model id to associate with traces/evaluation runs.
# MLFLOW_ACTIVE_MODEL_ID=model-123

# DSPy autologging controls for compile/eval flows.
MLFLOW_DSPY_LOG_TRACES_FROM_COMPILE=false
MLFLOW_DSPY_LOG_TRACES_FROM_EVAL=true
MLFLOW_DSPY_LOG_COMPILES=false
MLFLOW_DSPY_LOG_EVALS=false

#
# NOTES:
# - Daytona credentials are per-user: set DAYTONA_API_KEY and DAYTONA_API_URL
# - LM credentials are configured via DSPY_LM_MODEL and DSPY_LLM_API_KEY / DSPY_LM_API_KEY
# - Never commit this file once filled with real secrets
# - For team setups, use your secret manager instead of .env
#
